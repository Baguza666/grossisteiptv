  { name: "Silver", credits: "150–499", price: "20", margin: "40–60€", ideal: "Revendeur actif" },
  { name: "Gold", credits: "500–999", price: "18", margin: "42–62€", ideal: "Revendeur établi" },
  { name: "Platinum", credits: "1000+", price: "15", margin: "45–65€", ideal: "Grossiste / réseau" },
