              { href: "/grossiste-iptv-france", title: "Grossiste IPTV France", desc: "Pourquoi acheter chez un grossiste spécialisé B2B" },
              { href: "/comment-devenir-revendeur-iptv", title: "Comment devenir revendeur IPTV", desc: "Guide pas à pas pour lancer votre activité" },
              { href: "/guide-panel-iptv-revendeur", title: "Guide Panel IPTV Revendeur", desc: "Le guide complet pour maîtriser votre panel" },
            ].map(link => (
              <a href={link.href} class="bg-white/3 hover:bg-white/6 border border-white/8 hover:border-emerald-500/30 rounded-2xl p-5 group transition-all duration-200">
