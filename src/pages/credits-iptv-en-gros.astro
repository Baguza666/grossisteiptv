  <body class="bg-[#0B0F19] text-white antialiased min-h-screen flex flex-col relative overflow-x-hidden" style="font-family: 'Inter', sans-serif;">

    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
