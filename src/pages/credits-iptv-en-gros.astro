                <div class="text-slate-500 text-xs">{link.desc}</div>
              </a>
            ))}
          </div>
        </section>

        {/* CTA final */}
        <section class="bg-gradient-to-r from-emerald-900/30 to-slate-900/40 border border-emerald-500/20 rounded-3xl p-8 text-center">
          <h2 class="text-2xl font-bold mb-3 text-white">Demandez votre tarif personnalisé</h2>
          <p class="text-slate-400 text-sm mb-6 max-w-xl mx-auto">Indiquez votre volume cible et nous vous envoyons le tarif exact avec les serveurs disponibles. Réponse sous 30 minutes.</p>
          <a href={`https://wa.me/${phone}?text=Bonjour%2C%20je%20souhaite%20acheter%20des%20cr%C3%A9dits%20IPTV%20en%20gros.%20Pouvez-vous%20m%27envoyer%20vos%20tarifs%20actuels%20%3F`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-4 rounded-xl font-bold text-sm transition-all duration-300">
            Obtenir les tarifs — WhatsApp
          </a>
        </section>

      </div>
    </main>

