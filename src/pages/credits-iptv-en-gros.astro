            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 min-w-[420px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              <div class="pt-3">
                <div class="bg-[#0D1117] border border-white/10 rounded-xl p-5 shadow-2xl grid grid-cols-2 gap-5">
                  <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-3">Comprendre l'IPTV</p>
                    <div class="space-y-2.5">
                      <a href="/qu-est-ce-qu-un-panel-iptv" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-[12px]"><span class="text-indigo-400 text-[10px]">→</span>Qu'est-ce qu'un Panel IPTV ?</a>
                      <a href="/xtream-ui-panel-revendeur" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-[12px]"><span class="text-indigo-400 text-[10px]">→</span>Xtream UI Panel Revendeur</a>
                      <a href="/guide-panel-iptv-revendeur" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-[12px]"><span class="text-indigo-400 text-[10px]">→</span>Guide Panel Revendeur</a>
