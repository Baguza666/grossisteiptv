  </head>
  <body class="bg-[#0B0F19] text-white antialiased min-h-screen flex flex-col relative overflow-x-hidden" style="font-family: 'Inter', sans-serif;">

    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
      <div class="absolute top-[-20%] left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-cyan-600/12 blur-[150px] rounded-full"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[400px] bg-indigo-600/8 blur-[120px] rounded-full"></div>
    </div>

    <header class="sticky top-0 z-50 w-full border-b border-white/5 bg-[#0B0F19]/60 backdrop-blur-2xl">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-black tracking-tighter text-white"><img src="/grossisteiptvlogo.png" alt="Grossiste IPTV" class="h-7 w-auto" /></a>
        <nav class="hidden md:flex items-center gap-8 text-[13px] font-medium text-slate-400">
