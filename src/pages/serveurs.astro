                      <div class="text-sm font-bold text-white">{server.tv}</div>
                    </div>
                    <div class="text-center border-x border-white/5">
                      <div class="text-[10px] text-slate-500 uppercase tracking-wider font-semibold mb-0.5">🎬 VOD</div>
                      <div class="text-sm font-bold text-white">{server.vod}</div>
                    </div>
                    <div class="text-center">
                      <div class="text-[10px] text-slate-500 uppercase tracking-wider font-semibold mb-0.5">▶️ Séries</div>
                      <div class="text-sm font-bold text-white">{server.series}</div>
                    </div>
                  </div>

                  {/* ── WhatsApp CTA ── */}
