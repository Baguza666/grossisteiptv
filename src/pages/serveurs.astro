              const waText = encodeURIComponent(`Bonjour, je souhaite les tarifs de gros pour ${server.name}`);
              const waLink = `https://wa.me/${phone}?text=${waText}`;
              const isPerfect = server.rating === "5.0";

              return (
                <div class="group relative flex flex-col bg-white/[0.03] border border-white/[0.06] hover:border-indigo-500/30 rounded-2xl p-6 transition-all duration-500 hover:-translate-y-1 hover:bg-white/[0.05] hover:shadow-xl hover:shadow-indigo-500/5">

