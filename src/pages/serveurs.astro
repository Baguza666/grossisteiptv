                      <div class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-bold mt-1 ${
                        isPerfect
                          ? "bg-amber-500/15 text-amber-400 border border-amber-500/20"
                          : "bg-white/5 text-amber-400/80 border border-white/10"
