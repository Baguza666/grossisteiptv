---
import "../styles/global.css";
const phone = "212782389820";
const servers = [
  { name: "Lion OTT", rating: "4.9", tv: "20 000+", vod: "60 000+", series: "15 000+", uptime: "99.9%", highlight: "Stabilité 4K HEVC", best: false },
  { name: "Orca Pro Max", rating: "5.0", tv: "18 000+", vod: "80 000+", series: "22 000+", uptime: "99.9%", highlight: "Notre bestseller", best: true },
  { name: "Max OTT", rating: "4.8", tv: "15 000+", vod: "80 000+", series: "20 000+", uptime: "99.8%", highlight: "Plus grande VOD", best: false },
  { name: "Dream 4K", rating: "4.7", tv: "18 500+", vod: "50 000+", series: "10 000+", uptime: "99.7%", highlight: "RAW non compressé", best: false },
  { name: "Dino IPTV", rating: "4.9", tv: "19 000+", vod: "55 000+", series: "12 000+", uptime: "99.9%", highlight: "Zapping ultra-rapide", best: false },
  { name: "Trex IPTV", rating: "4.5", tv: "22 000+", vod: "70 000+", series: "25 000+", uptime: "99.6%", highlight: "Meilleur rapport Q/P", best: false },
  { name: "Magnum OTT", rating: "4.6", tv: "17 000+", vod: "40 000+", series: "9 000+", uptime: "99.8%", highlight: "Haute capacité Tank", best: false },
];
