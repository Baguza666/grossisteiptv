          <a href="/guide-panel-iptv-revendeur" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 text-white px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300">
            Guide complet panel IPTV →
          </a>
        </div>
      </section>

      <div class="max-w-4xl mx-auto px-6 pb-20 space-y-10">

        {/* Tableau comparatif rapide */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Tableau comparatif — vue rapide</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-xs border-collapse">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">#</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">Panel</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">Note</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">Chaînes</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">VOD</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">Uptime</th>
                  <th class="text-left py-3 px-3 text-slate-400 font-medium">Idéal pour</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {panels.map((p) => (
                  <tr class={`hover:bg-white/2 transition-colors ${p.rank === 1 ? 'bg-amber-500/5' : ''}`}>
                    <td class="py-2.5 px-3 text-slate-500 font-bold">#{p.rank}</td>
                    <td class="py-2.5 px-3 font-semibold text-white">{p.name}</td>
                    <td class="py-2.5 px-3 text-amber-400">{p.rating}★</td>
                    <td class="py-2.5 px-3 text-slate-300">{p.tv}</td>
                    <td class="py-2.5 px-3 text-slate-300">{p.vod}</td>
                    <td class={`py-2.5 px-3 font-semibold ${p.uptime === '99.9%' ? 'text-emerald-400' : 'text-emerald-300'}`}>{p.uptime}</td>
                    <td class="py-2.5 px-3 text-slate-400">{p.best_for.split(',')[0]}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {/* Fiches détaillées */}
        <section>
          <h2 class="text-2xl font-bold mb-6 text-white">Fiches détaillées — analyse complète</h2>
          <div class="space-y-6">
            {panels.map((p) => (
              <div class={`border rounded-3xl p-6 ${p.rank === 1 ? 'bg-amber-500/5 border-amber-500/20' : 'bg-white/3 border-white/8'}`}>
                <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-2xl bg-white/8 flex items-center justify-center text-slate-400 font-black text-sm">#{p.rank}</div>
                    <div>
                      <div class="flex items-center gap-2">
                        <h3 class="text-xl font-black text-white">{p.name}</h3>
                        <span class="text-amber-400 font-semibold">{p.rating}★</span>
                      </div>
                      <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full border ${p.badgeColor}`}>{p.badge}</span>
                    </div>
                  </div>
                  <div class="grid grid-cols-3 gap-3 text-center">
                    <div class="bg-white/5 rounded-xl px-3 py-2">
                      <div class="text-white font-bold text-sm">{p.tv}</div>
                      <div class="text-slate-500 text-xs">Chaînes</div>
                    </div>
                    <div class="bg-white/5 rounded-xl px-3 py-2">
                      <div class="text-white font-bold text-sm">{p.vod}</div>
                      <div class="text-slate-500 text-xs">VOD</div>
                    </div>
                    <div class="bg-white/5 rounded-xl px-3 py-2">
                      <div class="text-emerald-400 font-bold text-sm">{p.uptime}</div>
                      <div class="text-slate-500 text-xs">Uptime</div>
                    </div>
                  </div>
                </div>
                <div class="grid md:grid-cols-2 gap-4 mb-4">
                  <div>
                    <div class="text-xs text-slate-500 uppercase tracking-wider mb-2">Points forts</div>
                    <ul class="space-y-1">
                      {p.pros.map(pro => (
                        <li class="text-sm text-slate-300 flex gap-2"><span class="text-emerald-400 flex-shrink-0">✓</span>{pro}</li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <div class="text-xs text-slate-500 uppercase tracking-wider mb-2">À considérer</div>
                    <ul class="space-y-1">
                      {p.cons.map(con => (
                        <li class="text-sm text-slate-400 flex gap-2"><span class="text-slate-600 flex-shrink-0">—</span>{con}</li>
                      ))}
                    </ul>
                    <div class="mt-3">
                      <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Idéal pour</div>
                      <div class="text-sm text-indigo-300">{p.best_for}</div>
                    </div>
                  </div>
                </div>
                <div class="bg-white/5 rounded-xl p-3 text-sm">
                  <span class="text-slate-400">Verdict : </span>
                  <span class="text-white">{p.verdict}</span>
                </div>
              </div>
            ))}
          </div>
        </section>

