                    <option value="Orca Pro Max">Orca Pro Max</option>
                    <option value="Avatar Pro">Avatar Pro</option>
                    <option value="Trex IPTV">Trex IPTV</option>
                    <option value="Mega OTT">Mega OTT</option>
                    <option value="Iron Pro">Iron Pro</option>
                    <option value="Crystal OTT">Crystal OTT</option>
                  </select>
                </div>

                <div class="space-y-2">
                  <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider">Volume de Crédits</label>
                  <div class="grid grid-cols-3 gap-2">
                    <label class="cursor-pointer">
                      <input type="radio" name="credits" value="10" class="peer sr-only" checked />
                      <div class="text-center py-2.5 rounded-lg border border-white/10 bg-white/5 peer-checked:border-indigo-500 peer-checked:bg-indigo-500/10 transition-all text-sm font-medium text-slate-400 peer-checked:text-indigo-400">10</div>
                    </label>
                    <label class="cursor-pointer">
                      <input type="radio" name="credits" value="50" class="peer sr-only" />
                      <div class="text-center py-2.5 rounded-lg border border-white/10 bg-white/5 peer-checked:border-indigo-500 peer-checked:bg-indigo-500/10 transition-all text-sm font-medium text-slate-400 peer-checked:text-indigo-400">50</div>
                    </label>
                    <label class="cursor-pointer">
                      <input type="radio" name="credits" value="100+" class="peer sr-only" />
                      <div class="text-center py-2.5 rounded-lg border border-white/10 bg-white/5 peer-checked:border-indigo-500 peer-checked:bg-indigo-500/10 transition-all text-sm font-medium text-slate-400 peer-checked:text-indigo-400">100+</div>
