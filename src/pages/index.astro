              </a>
            </div>

            {/* Trust KPIs */}
            <div class="flex items-center gap-8 pt-6 border-t border-white/5">
              <div>
                <div class="text-2xl font-extrabold text-white">120+</div>
                <div class="text-xs text-slate-400 font-medium">Revendeurs actifs</div>
              </div>
