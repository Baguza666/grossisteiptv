      ══════════════════════════════════════════════════════════ */}
      <section class="w-full border-y border-white/5 py-5 overflow-hidden relative z-10" aria-hidden="true">
        <div class="flex animate-marquee whitespace-nowrap">
          {[...Array(2)].map(() => (
            <div class="flex items-center gap-12 mx-8 shrink-0">
              {["Orca Pro Max", "Avatar Pro", "Trex IPTV", "Mega OTT", "Iron Pro", "Crystal OTT", "King365", "Atlas Pro", "Cobra", "Dream", "Volka", "4K OTT", "Smarters Pro"].map((name) => (
                <span class="text-sm font-medium text-slate-600 flex items-center gap-2.5">
                  <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                  {name}
                </span>
              ))}
            </div>
          ))}
        </div>
      </section>

      {/* ══════════════════════════════════════════════════════════
          BENTO BOX — Why Us Features
      ══════════════════════════════════════════════════════════ */}
      <section class="max-w-7xl mx-auto px-6 py-24 reveal">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">
            Une infrastructure conçue pour les <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-400">revendeurs IPTV premium</span>
          </h2>
          <p class="text-slate-400 max-w-2xl mx-auto">Chaque composant de notre réseau est optimisé pour maximiser la rentabilité de votre activité de revendeur IPTV et fidéliser votre base clients.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          {/* Card 1 — Large (Anti-Freeze) */}
          <div class="md:col-span-2 md:row-span-2 group bg-[#0f1420] border border-white/5 hover:border-indigo-500/30 rounded-2xl p-8 transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-48 h-48 bg-indigo-500/5 rounded-full blur-3xl group-hover:bg-indigo-500/10 transition-all duration-700"></div>
            <div class="relative z-10 h-full flex flex-col">
              <div class="w-10 h-10 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-6 text-lg">🛡️</div>
              <h3 class="text-xl font-bold mb-3">Infrastructure Anti-Freeze</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-6">Notre technologie propriétaire contourne automatiquement les blocages FAI (Orange, Free, SFR, Bouygues) pendant les grands événements sportifs. Uptime réel de 99.9% vérifié sur 365 jours. Vos clients ne subiront plus jamais de coupure.</p>
              <div class="grid grid-cols-2 gap-3 mt-auto">
