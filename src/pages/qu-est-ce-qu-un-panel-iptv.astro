            {[
              { step: "01", title: "Le serveur IPTV", desc: "Stocke et diffuse les flux TV en direct, les films VOD et les séries. C'est l'infrastructure technique (ex. Lion OTT, Orca Pro Max)." },
              { step: "02", title: "Le panel Xtream UI", desc: "L'interface web de gestion. Vous créez les lignes abonnement ici, gérez les crédits, consultez les stats. Accessible via navigateur." },
              { step: "03", title: "L'application client", desc: "Votre client utilise l'appli (IPTV Smarters, TiViMate, etc.) avec ses identifiants. Il ne voit jamais votre panel ni vos fournisseurs." }
            ].map(item => (
              <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
                <div class="text-indigo-400 font-black text-2xl mb-2">{item.step}</div>
                <h3 class="font-bold text-white mb-2 text-sm">{item.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
