                <div class="flex flex-wrap gap-2">
                  {item.pros.map(pro => (
                    <span class="text-xs bg-white/5 text-slate-300 px-2.5 py-1 rounded-lg">{pro}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Ce dont vous avez besoin */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Ce dont vous avez besoin pour démarrer comme revendeur IPTV</h2>
          <p class="text-slate-300 leading-relaxed mb-6">Pour lancer votre activité de revente avec un panel IPTV, voici le minimum nécessaire :</p>
          <div class="grid md:grid-cols-2 gap-4">
            {[
              { icon: "🔑", title: "Un accès panel chez un grossiste", desc: "Vous obtenez un compte revendeur avec un quota initial de crédits. Chez nous : à partir de 50 crédits pour commencer." },
              { icon: "💳", title: "Des crédits IPTV en gros", desc: "Chaque crédit = 1 abonnement 1 mois pour 1 client. Achetez en volume pour maximiser la marge. Voir les <a href='/credits-iptv-en-gros' class='text-indigo-400 hover:text-indigo-300 underline underline-offset-2'>tarifs crédits en gros</a>." },
