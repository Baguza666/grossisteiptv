      const mCloseBtn = document.getElementById('mobile-close-btn');
      const mMenu = document.getElementById('mobile-menu');
      const mBackdrop = document.getElementById('mobile-backdrop');
      const mDrawer = document.getElementById('mobile-drawer');
      function openNav() {
        mMenu?.classList.remove('pointer-events-none');
        mBackdrop?.classList.remove('opacity-0');
        mBackdrop?.classList.add('opacity-100');
        mDrawer?.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      }
      function closeNav() {
        mBackdrop?.classList.add('opacity-0');
        mBackdrop?.classList.remove('opacity-100');
        mDrawer?.classList.add('translate-x-full');
        document.body.style.overflow = '';
        setTimeout(() => mMenu?.classList.add('pointer-events-none'), 300);
      }
      mMenuBtn?.addEventListener('click', openNav);
      mCloseBtn?.addEventListener('click', closeNav);
      mBackdrop?.addEventListener('click', closeNav);
      mMenu?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeNav));
    </script>
