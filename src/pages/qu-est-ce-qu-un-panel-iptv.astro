                  ["Prix d'achat", "5–25€/crédit en gros", "15–60€/abonnement"],
                  ["Prix de revente", "Vous fixez librement", "Non applicable"],
                  ["Marge", "30–50€ par abonnement", "0€"],
                  ["Gestion clients", "Panel centralisé", "Aucune"],
                  ["Création de lignes", "Instantanée, autonome", "Dépend du fournisseur"],
                  ["Scalabilité", "Illimitée (crédits à la demande)", "Contrat individuel"],
