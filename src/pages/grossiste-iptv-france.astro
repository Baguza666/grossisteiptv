      </section>

      <div class="max-w-4xl mx-auto px-6 pb-20 space-y-16">

        {/* Pourquoi B2B uniquement */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Pourquoi choisir un grossiste IPTV B2B plutôt qu'un revendeur particulier ?</h2>
          <p class="text-slate-300 leading-relaxed mb-6">
            En France, le marché IPTV se divise en deux catégories : les revendeurs particuliers (qui achètent au détail et revendent avec une petite marge) et les grossistes B2B (qui achètent en volume et proposent des tarifs structurés). La différence impacte directement votre rentabilité.
          </p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-3 px-4 text-slate-400 font-medium">Critère</th>
                  <th class="text-left py-3 px-4 text-indigo-300 font-semibold">Grossiste B2B (nous)</th>
                  <th class="text-left py-3 px-4 text-slate-400 font-medium">Revendeur particulier</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {[
                  ["Prix par crédit", "15–22€ (dégressif)", "25–35€ (marge intégrée)"],
                  ["Marge revendeur", "40–65€/abonnement", "15–25€/abonnement"],
                  ["Infrastructure", "Serveurs propres, 99.9% uptime", "Dépend du fournisseur amont"],
                  ["Support", "WhatsApp dédié revendeur B2B", "Disponibilité variable"],
                  ["Facturation", "Crédits sans expiration", "Abonnements mensuels forcés"],
                  ["Scalabilité", "Illimitée à la demande", "Limitée par stock particulier"],
                  ["Fiabilité", "Structure professionnelle", "Risque de disparition"],
                ].map(([crit, b2b, part]) => (
                  <tr class="hover:bg-white/2 transition-colors">
                    <td class="py-3 px-4 text-slate-400">{crit}</td>
                    <td class="py-3 px-4 text-white font-medium">{b2b}</td>
                    <td class="py-3 px-4 text-slate-500">{part}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {/* Notre offre grossiste */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Notre offre grossiste IPTV en France</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {[
              { icon: "🎛️", title: "Panel Xtream UI complet", desc: "Accès à votre espace revendeur Xtream UI. Créez des lignes illimitées, gérez vos clients, consultez les stats en temps réel." },
              { icon: "💳", title: "Crédits à tarifs dégressifs", desc: "De 22€/crédit (50 crédits) à 15€/crédit (1000+ crédits). Aucune expiration. Rechargez à la demande sans contrat long terme." },
              { icon: "🖥️", title: "7 serveurs premium", desc: "Lion OTT, Orca Pro Max, Max OTT, Dream 4K, Dino IPTV, Trex IPTV, Magnum OTT. Tous sur Xtream UI, tous testés par notre équipe." },
              { icon: "📱", title: "Support WhatsApp B2B", desc: "Groupe WhatsApp dédié revendeurs. Réponse garantie en moins de 1 heure. Assistance technique, recharges crédits, incidents serveur." },
              { icon: "🔄", title: "Pas de contrat ni d'engagement", desc: "Achetez des crédits quand vous en avez besoin. Pas d'abonnement mensuel obligatoire, pas de pénalité d'arrêt." },
              { icon: "🏪", title: "Sous-revendeurs possibles", desc: "Créez vos propres sous-revendeurs avec quotas personnalisés. Construisez un réseau et démultipliez vos revenus sans effort supplémentaire." },
            ].map(item => (
              <div class="bg-white/3 border border-white/8 rounded-2xl p-5 flex gap-4">
                <div class="text-2xl flex-shrink-0">{item.icon}</div>
                <div>
                  <h3 class="font-semibold text-white text-sm mb-1">{item.title}</h3>
                  <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Tarifs indicatifs */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Tarifs grossiste — crédits IPTV en gros</h2>
          <p class="text-slate-400 text-sm mb-6">Tarifs indicatifs au 2026-04-23. Contactez-nous pour un tarif personnalisé selon votre volume réel et votre historique de commande.</p>
          <div class="grid md:grid-cols-4 gap-3">
            {[
              { tier: "Bronze", credits: "50–149", price: "22€", margin: "38–58€" },
              { tier: "Silver", credits: "150–499", price: "20€", margin: "40–60€" },
              { tier: "Gold", credits: "500–999", price: "18€", margin: "42–62€" },
              { tier: "Platinum", credits: "1000+", price: "15€", margin: "45–65€" },
            ].map((t, i) => (
              <div class={`rounded-2xl p-4 border text-center ${i === 1 ? 'bg-indigo-600/10 border-indigo-500/30' : 'bg-white/3 border-white/8'}`}>
                <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider mb-1">{t.tier}</div>
                <div class="text-lg font-black text-white mb-0.5">{t.price}<span class="text-sm font-normal text-slate-400">/crédit</span></div>
                <div class="text-xs text-slate-500 mb-2">{t.credits} crédits</div>
                <div class="text-xs text-emerald-400 font-semibold">Marge {t.margin}</div>
              </div>
            ))}
          </div>
          <div class="mt-6 text-center">
            <a href="/credits-iptv-en-gros" class="text-sm text-indigo-400 hover:text-indigo-300 underline underline-offset-2 transition-colors">Voir le simulateur de rentabilité complet →</a>
          </div>
        </section>

        {/* Serveurs disponibles */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Serveurs disponibles dans notre réseau grossiste</h2>
          <div class="grid md:grid-cols-2 gap-3">
            {[
              { name: "Lion OTT", rating: "4.9★", tv: "20 000+", vod: "60 000+" },
              { name: "Orca Pro Max", rating: "5.0★", tv: "18 000+", vod: "80 000+" },
              { name: "Max OTT", rating: "4.8★", tv: "15 000+", vod: "80 000+" },
              { name: "Dream 4K", rating: "4.7★", tv: "18 500+", vod: "50 000+" },
              { name: "Dino IPTV", rating: "4.9★", tv: "19 000+", vod: "55 000+" },
              { name: "Trex IPTV", rating: "4.5★", tv: "22 000+", vod: "70 000+" },
            ].map(s => (
              <div class="bg-white/3 border border-white/8 rounded-xl p-4 flex items-center justify-between gap-3">
                <div>
                  <div class="font-semibold text-white text-sm">{s.name} <span class="text-amber-400 text-xs">{s.rating}</span></div>
                  <div class="text-slate-500 text-xs mt-0.5">{s.tv} chaînes · {s.vod} VOD</div>
                </div>
                <a href="/serveurs" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">Détails →</a>
              </div>
            ))}
          </div>
        </section>

        {/* Comment devenir partenaire */}
        <section>
          <h2 class="text-2xl font-bold mb-4 text-white">Comment devenir partenaire grossiste</h2>
          <div class="space-y-3">
            {[
              { step: "1", title: "Contactez-nous sur WhatsApp", desc: "Présentez votre projet revendeur et votre volume estimé. Nous évaluons votre demande et vous envoyons notre offre personnalisée sous 30 minutes." },
              { step: "2", title: "Testez nos serveurs gratuitement", desc: "Nous vous offrons une période de test sur nos serveurs principaux. Vérifiez la qualité des flux, la stabilité et l'interface du panel avant tout engagement." },
              { step: "3", title: "Achetez votre premier stock de crédits", desc: "Démarrez avec le volume qui correspond à votre activité actuelle. Les crédits n'expirent pas — aucune pression sur l'utilisation." },
              { step: "4", title: "Rejoignez le groupe WhatsApp revendeur", desc: "Accès au groupe B2B exclusif : annonces de maintenance, nouvelles fonctionnalités, recharges crédits express, et support technique dédié." },
            ].map(item => (
              <div class="flex gap-4 bg-white/3 border border-white/8 rounded-2xl p-5">
                <div class="w-8 h-8 rounded-full bg-indigo-500/15 border border-indigo-500/20 flex items-center justify-center text-indigo-400 font-black text-sm flex-shrink-0">{item.step}</div>
                <div>
                  <h3 class="font-semibold text-white text-sm mb-1">{item.title}</h3>
                  <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        {/* Liens internes */}
        <section>
          <h2 class="text-xl font-bold mb-5 text-white">Ressources pour revendeurs</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {[
              { href: "/credits-iptv-en-gros", title: "Crédits IPTV en gros", desc: "Tarifs dégressifs et simulateur rentabilité" },
              { href: "/guide-panel-iptv-revendeur", title: "Guide Panel IPTV Revendeur", desc: "Tout sur le fonctionnement et la gestion" },
              { href: "/comment-devenir-revendeur-iptv", title: "Comment devenir revendeur IPTV", desc: "Guide pas à pas pour démarrer en France" },
              { href: "/meilleur-panel-iptv-revendeur", title: "Meilleur panel IPTV revendeur", desc: "Comparatif de nos 7 serveurs" },
            ].map(link => (
              <a href={link.href} class="bg-white/3 hover:bg-white/6 border border-white/8 hover:border-indigo-500/30 rounded-2xl p-5 group transition-all duration-200">
                <div class="font-semibold text-white group-hover:text-indigo-300 text-sm mb-1 transition-colors">{link.title} →</div>
                <div class="text-slate-500 text-xs">{link.desc}</div>
              </a>
            ))}
          </div>
        </section>

        {/* CTA final */}
        <section class="bg-gradient-to-r from-indigo-900/40 to-slate-900/40 border border-indigo-500/20 rounded-3xl p-8 text-center">
          <h2 class="text-2xl font-bold mb-3 text-white">Rejoindre le réseau grossiste GrossisteIPTV</h2>
          <p class="text-slate-400 text-sm mb-2 max-w-xl mx-auto">120+ revendeurs actifs. Panel Xtream UI, 7 serveurs premium, crédits à partir de 15€, support WhatsApp VIP.</p>
          <p class="text-slate-500 text-xs mb-6">Réponse sous 30 minutes. Pas de contrat long terme. Accès panel immédiat après paiement.</p>
          <a href={`https://wa.me/${phone}?text=Bonjour%2C%20je%20suis%20int%C3%A9ress%C3%A9%20par%20une%20offre%20grossiste%20IPTV%20B2B.%20Pouvez-vous%20me%20pr%C3%A9senter%20vos%20tarifs%20%3F`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-4 rounded-xl font-bold text-sm transition-all duration-300">
            Demander les tarifs grossiste — WhatsApp
