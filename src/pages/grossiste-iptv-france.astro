                      <a href="/guide-panel-iptv-revendeur" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-[12px]"><span class="text-indigo-400 text-[10px]">→</span>Guide Panel Revendeur</a>
                    </div>
                  </div>
                  <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-3">Devenir Revendeur</p>
