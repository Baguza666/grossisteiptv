        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          Grossiste IPTV B2B France
        </div>
        <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight mb-6">
          Le <span class="text-indigo-400">Grossiste IPTV France</span><br />100% B2B pour Revendeurs
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed mb-8 max-w-3xl mx-auto">
          GrossisteIPTV est le fournisseur B2B de référence pour les revendeurs IPTV professionnels en France. Panels Xtream UI, crédits à tarifs dégressifs, 7 serveurs premium, et support WhatsApp dédié — aucune vente au détail.
        </p>
        {/* Trust metrics */}
        <div class="grid grid-cols-3 gap-4 mb-8 max-w-lg mx-auto">
          {[
            { val: "120+", label: "Revendeurs actifs" },
            { val: "7", label: "Serveurs premium" },
            { val: "99.9%", label: "Uptime garanti" },
          ].map(stat => (
            <div class="bg-white/5 border border-white/8 rounded-2xl p-4">
              <div class="text-2xl font-black text-white mb-1">{stat.val}</div>
              <div class="text-slate-500 text-xs">{stat.label}</div>
            </div>
          ))}
        </div>
        <a href={`https://wa.me/${phone}?text=Bonjour%2C%20je%20suis%20int%C3%A9ress%C3%A9%20par%20une%20offre%20grossiste%20IPTV%20B2B.%20Pouvez-vous%20me%20pr%C3%A9senter%20vos%20tarifs%20%3F`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-4 rounded-xl font-bold text-sm transition-all duration-300">
          Obtenir les tarifs grossiste — WhatsApp
