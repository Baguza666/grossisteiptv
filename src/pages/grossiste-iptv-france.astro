          <a href="/" class="hover:text-white transition-colors duration-200">Accueil</a>
          <a href="/serveurs" class="hover:text-white transition-colors duration-200">Serveurs</a>
          <div class="relative group">
            <button class="flex items-center gap-1 text-white transition-colors duration-200 cursor-pointer bg-transparent border-0 p-0 text-[13px] font-medium">
              Guides
